.h-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xxl) 0;
  text-align: center;
}

.h-empty__icon {
  font-size: 96rpx;
  margin-bottom: var(--spacing-lg);
  opacity: 0.3;
}

.h-empty__title {
  display: block;
  font-family: var(--font-serif);
  font-size: 40rpx;
  font-weight: 400;
  margin-bottom: var(--spacing-md);
  color: var(--color-text-primary);
}

.h-empty__desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}
