.h-pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-md);
  padding: var(--spacing-lg) 0;
  margin-top: var(--spacing-xl);
  border-top: 1rpx solid var(--color-border);
}

.page-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  background: rgba(26, 26, 26, 0.6);
  color: var(--color-text-primary);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  min-height: 80rpx;
  font-size: 24rpx;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.page-btn::after {
  border: none;
}

.page-btn[disabled] {
  opacity: 0.3;
}

.page-arrow {
  font-size: 28rpx;
}

.page-text {
  font-size: 24rpx;
}

.page-info {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-xs);
  min-width: 100rpx;
  justify-content: center;
}

.page-current {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.page-separator {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.page-total {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}
