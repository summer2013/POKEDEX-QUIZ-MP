.detail-page {
  min-height: 100vh;
  padding: var(--spacing-lg);
  padding-bottom: 120rpx;
}

.hero {
  padding: var(--spacing-xxl);
  border-radius: var(--radius-lg);
  text-align: center;
  margin-bottom: var(--spacing-xxl);
  border: 1rpx solid;
  box-shadow: var(--shadow-lg);
  position: relative;
  overflow: hidden;
  animation: fadeInScale 0.5s ease;
}

.hero-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, transparent 0%, currentColor 50%, transparent 100%);
  opacity: 0.5;
}

.pokemon-id {
  margin-bottom: var(--spacing-md);
}

.id-label {
  font-size: 22rpx;
  opacity: 0.6;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-right: var(--spacing-xs);
}

.id-value {
  font-family: var(--font-serif);
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 0.05em;
}

.pokemon-name {
  display: block;
  font-family: var(--font-serif);
  font-size: 64rpx;
  font-weight: 400;
  text-transform: capitalize;
  margin-bottom: var(--spacing-lg);
}

.types {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-md);
}

.type-badge {
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  padding: var(--spacing-sm) var(--spacing-lg);
}

.type-text {
  font-size: 22rpx;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  font-weight: 600;
}

.stats-section {
  margin-bottom: var(--spacing-xxl);
}

.section-title {
  display: block;
  font-family: var(--font-serif);
  font-size: 40rpx;
  font-weight: 400;
  color: var(--color-primary);
  margin-bottom: var(--spacing-lg);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-md);
}

.stat-card {
  background: linear-gradient(135deg, rgba(42, 42, 42, 0.8) 0%, rgba(26, 26, 26, 0.8) 100%);
  border: 1rpx solid var(--color-border-subtle);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
  transition: all 0.3s ease;
  animation: fadeIn 0.5s ease forwards;
  opacity: 0;
}

.stat-card:nth-child(1) { animation-delay: 0.1s; }
.stat-card:nth-child(2) { animation-delay: 0.15s; }
.stat-card:nth-child(3) { animation-delay: 0.2s; }
.stat-card:nth-child(4) { animation-delay: 0.25s; }

.stat-icon {
  font-size: 40rpx;
}

.stat-label {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
  font-family: var(--font-serif);
}

.abilities-section {
  margin-bottom: var(--spacing-xxl);
}

.abilities-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-lg);
}

.ability-card {
  background: linear-gradient(135deg, rgba(42, 42, 42, 0.9) 0%, rgba(26, 26, 26, 0.9) 100%);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-xl);
  animation: fadeIn 0.5s ease forwards;
  opacity: 0;
}

.ability-card:nth-child(1) { animation-delay: 0.3s; }
.ability-card:nth-child(2) { animation-delay: 0.35s; }
.ability-card:nth-child(3) { animation-delay: 0.4s; }

.ability-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.ability-name-group {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.ability-name {
  font-size: 32rpx;
  font-weight: 600;
  text-transform: capitalize;
}

.ability-badge {
  display: inline-flex;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}

.badge-text {
  font-size: 18rpx;
  color: #0a0a0a;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  font-weight: 700;
}

.ability-slot {
  font-size: 20rpx;
  color: var(--color-primary);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  background: rgba(201, 169, 97, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--color-border);
}

.ability-effect {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--color-text-secondary);
  background: rgba(10, 10, 10, 0.4);
  padding: var(--spacing-md);
  border-radius: var(--radius-sm);
  border-left: 3rpx solid var(--color-primary);
  display: block;
}

.back-btn {
  width: 100%;
  background: rgba(26, 26, 26, 0.9);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-md);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  transition: all 0.3s ease;
  margin-top: var(--spacing-xl);
}

.back-btn::after {
  border: none;
}

.back-btn:active {
  background: rgba(42, 42, 42, 0.9);
  transform: scale(0.98);
}

.back-arrow {
  font-size: 32rpx;
}
