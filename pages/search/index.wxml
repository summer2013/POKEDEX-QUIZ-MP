<view class="search-page">
  <view class="welcome-modal" wx:if="{{showWelcome}}" catchtap="hideWelcome">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-icon">⚡</view>
      <text class="modal-title">Welcome to</text>
      <text class="modal-brand">Hilton Pokédex</text>
      <text class="modal-subtitle">An Exclusive Digital Experience</text>
      <button class="modal-btn" bindtap="hideWelcome">
        Begin Your Journey →
      </button>
    </view>
  </view>

  <view class="container flex flex-col {{showWelcome ? 'blur' : ''}}">
    <view class="header text-center">
      <view class="header-decoration"></view>
      <text class="header-brand">Hilton</text>
      <text class="header-title">Pokédex</text>
      <text class="header-subtitle">Curated Collection</text>
    </view>

    <view class="search-box w-full">
      <view class="search-input-wrapper flex items-center">
        <text class="search-icon">🔍</text>
        <input
          class="search-input flex-1"
          type="text"
          placeholder="Search Pokémon..."
          placeholder-class="placeholder"
          value="{{searchTerm}}"
          bindinput="onSearchInput"
          bindconfirm="onSearch"
        />
      </view>
    </view>

    <h-loading show="{{loading}}" text="{{loadingText}}" />

    <view class="results w-full" wx:if="{{!loading && results.length > 0}}">
      <view class="results-header">
        <text class="results-count text-upper">{{results.length}} Species Found</text>
      </view>

      <species-card
        wx:for="{{results}}"
        wx:key="id"
        species="{{item}}"
        index="{{index}}"
        bind:varietytap="onSpeciesVarietyTap"
      />

      <h-pagination
        page="{{page}}"
        total-pages="{{totalPages}}"
        has-more="{{hasMore}}"
        bindprev="onPaginationPrev"
        bindnext="onPaginationNext"
      />
    </view>

    <h-empty
      wx:if="{{!loading && searched && results.length === 0}}"
      icon="🔍"
      title="No Pokémon Found"
      description="Try a different search term"
    />
  </view>
</view>
