/**
 * 搜索页面 - 奢华样式
 */

.search-page {
  min-height: 100vh;
  position: relative;
}

/* ===== 欢迎模态框 ===== */
.welcome-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 10, 10, 0.95);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.4s ease;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background: linear-gradient(135deg, rgba(42, 42, 42, 0.95) 0%, rgba(26, 26, 26, 0.95) 100%);
  border-radius: var(--radius-lg);
  padding: var(--spacing-xxl);
  text-align: center;
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-xl);
  animation: fadeInScale 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.modal-icon {
  font-size: 100rpx;
  margin-bottom: var(--spacing-lg);
  animation: pulse 2s ease-in-out infinite;
}

.modal-title {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  letter-spacing: 0.3em;
  text-transform: uppercase;
  margin-bottom: var(--spacing-sm);
}

.modal-brand {
  display: block;
  font-family: var(--font-serif);
  font-size: 64rpx;
  font-weight: 300;
  color: var(--color-primary);
  margin-bottom: var(--spacing-md);
  text-shadow: 0 0 30rpx rgba(201, 169, 97, 0.3);
}

.modal-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  margin-bottom: var(--spacing-xl);
  font-style: italic;
}

.modal-btn {
  width: 100%;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #0a0a0a;
  border: none;
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  box-shadow: var(--shadow-md);
}

.modal-btn::after {
  border: none;
}

.blur {
  filter: blur(8rpx);
}

/* ===== 头部 ===== */
.header {
  text-align: center;
  padding: var(--spacing-xl) 0;
  margin-bottom: var(--spacing-lg);
}

.header-decoration {
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent 0%, var(--color-primary) 50%, transparent 100%);
  margin: 0 auto var(--spacing-md);
  border-radius: 2rpx;
}

.header-brand {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  letter-spacing: 0.4em;
  text-transform: uppercase;
  margin-bottom: var(--spacing-xs);
}

.header-title {
  display: block;
  font-family: var(--font-serif);
  font-size: 72rpx;
  font-weight: 300;
  color: var(--color-primary);
  margin-bottom: var(--spacing-xs);
}

.header-subtitle {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

/* ===== 搜索框 ===== */
/* ===== 搜索框 ===== */
.search-box {
  margin-bottom: var(--spacing-xxl);
}

.search-input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  background: rgba(26, 26, 26, 0.6);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border-subtle);
  transition: all 0.3s ease;
}

.search-input-wrapper:focus-within {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx rgba(201, 169, 97, 0.1);
}

.search-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  padding-left: var(--spacing-lg);
  font-size: 32rpx;
  opacity: 0.5;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  padding: var(--spacing-lg);
  padding-left: 0;
  background: transparent;
  border: none;
  color: var(--color-text-primary);
  font-size: 32rpx;
}

.placeholder {
  color: var(--color-text-tertiary);
  font-style: italic;
}


/* ===== 加载状态 ===== */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xxl) 0;
}

.spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid transparent;
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: var(--spacing-md);
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  letter-spacing: 0.05em;
}

/* ===== 结果 ===== */
.results-header {
  margin-bottom: var(--spacing-lg);
}

.results-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.species-card {
  margin-bottom: var(--spacing-xl);
  padding: var(--spacing-xl);
  border-radius: var(--radius-lg);
  border: 1rpx solid;
  box-shadow: var(--shadow-md);
  animation: fadeIn 0.5s ease forwards;
  opacity: 0;
}

.species-card:nth-child(1) { animation-delay: 0.05s; }
.species-card:nth-child(2) { animation-delay: 0.1s; }
.species-card:nth-child(3) { animation-delay: 0.15s; }
.species-card:nth-child(4) { animation-delay: 0.2s; }

.card-header {
  padding-bottom: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.species-name {
  display: block;
  font-family: var(--font-serif);
  font-size: 48rpx;
  font-weight: 400;
  text-transform: capitalize;
  margin-bottom: var(--spacing-md);
}

.capture-rate {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.rate-label {
  font-size: 22rpx;
  opacity: 0.7;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.rate-bar-container {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.rate-value {
  font-size: 32rpx;
  font-weight: 600;
  min-width: 60rpx;
}

.rate-bar {
  flex: 1;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 3rpx;
  overflow: hidden;
}

.rate-fill {
  height: 100%;
  background: currentColor;
  border-radius: 3rpx;
  transition: width 0.6s ease;
}

.pokemon-list {
  margin-top: var(--spacing-md);
}

.list-title {
  display: block;
  font-size: 22rpx;
  opacity: 0.8;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: var(--spacing-md);
}

.pokemon-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md);
  margin: var(--spacing-sm) 0;
  background: rgba(255, 255, 255, 0.05);
  border-radius: var(--radius-sm);
  transition: all 0.3s ease;
}

.pokemon-item:active {
  background: rgba(255, 255, 255, 0.15);
  transform: translateX(8rpx);
}

.pokemon-name {
  font-size: 30rpx;
  text-transform: capitalize;
}

.pokemon-arrow {
  font-size: 28rpx;
  opacity: 0.6;
}


/* ===== 分页 ===== */
.pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-md);  /* 👈 新增 */
  margin-top: var(--spacing-xxl);
  padding-top: var(--spacing-lg);
  border-top: 1rpx solid var(--color-border);
}

.page-btn {
  flex: 1;  /* 👈 改为 flex: 1 让两边等宽 */
  background: rgba(26, 26, 26, 0.6);
  color: var(--color-text-primary);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  font-size: 24rpx;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  
  /* 👇 新增：确保按钮内容居中 */
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;  /* 👈 新增：固定高度 */
}

.page-btn::after {
  border: none;
}

.page-btn[disabled] {
  opacity: 0.3;
}

.page-num {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
  min-width: 80rpx;  /* 👈 新增：固定页码宽度 */
  text-align: center;
}
/* ===== 空状态 ===== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xxl) 0;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: var(--spacing-lg);
  opacity: 0.3;
}

.empty-title {
  display: block;
  font-family: var(--font-serif);
  font-size: 40rpx;
  font-weight: 400;
  margin-bottom: var(--spacing-md);
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}
