.search-page {
  min-height: 100vh;
  position: relative;
}

.welcome-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 10, 10, 0.95);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.4s ease;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background: linear-gradient(135deg, rgba(42, 42, 42, 0.95) 0%, rgba(26, 26, 26, 0.95) 100%);
  border-radius: var(--radius-lg);
  padding: var(--spacing-xxl);
  text-align: center;
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-xl);
  animation: fadeInScale 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.modal-icon {
  font-size: 100rpx;
  margin-bottom: var(--spacing-lg);
  animation: pulse 2s ease-in-out infinite;
}

.modal-title {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  letter-spacing: 0.3em;
  text-transform: uppercase;
  margin-bottom: var(--spacing-sm);
}

.modal-brand {
  display: block;
  font-family: var(--font-serif);
  font-size: 64rpx;
  font-weight: 300;
  color: var(--color-primary);
  margin-bottom: var(--spacing-md);
  text-shadow: 0 0 30rpx rgba(201, 169, 97, 0.3);
}

.modal-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  margin-bottom: var(--spacing-xl);
  font-style: italic;
}

.modal-btn {
  width: 100%;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #0a0a0a;
  border: none;
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  box-shadow: var(--shadow-md);
}

.modal-btn::after {
  border: none;
}

.blur {
  filter: blur(8rpx);
}

.header {
  padding: var(--spacing-xl) 0;
  margin-bottom: var(--spacing-lg);
}

.header-decoration {
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent 0%, var(--color-primary) 50%, transparent 100%);
  margin: 0 auto var(--spacing-md);
  border-radius: 2rpx;
}

.header-brand {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  letter-spacing: 0.4em;
  text-transform: uppercase;
  margin-bottom: var(--spacing-xs);
}

.header-title {
  display: block;
  font-family: var(--font-serif);
  font-size: 72rpx;
  font-weight: 300;
  color: var(--color-primary);
  margin-bottom: var(--spacing-xs);
}

.header-subtitle {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

.search-box {
  margin-bottom: var(--spacing-xxl);
}

.search-input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  background: rgba(26, 26, 26, 0.6);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border-subtle);
  transition: all 0.3s ease;
}

.search-input-wrapper:focus-within {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx rgba(201, 169, 97, 0.1);
}

.search-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  padding-left: var(--spacing-lg);
  font-size: 32rpx;
  opacity: 0.5;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  padding: var(--spacing-lg);
  padding-left: 0;
  background: transparent;
  border: none;
  color: var(--color-text-primary);
  font-size: 32rpx;
}

.placeholder {
  color: var(--color-text-tertiary);
  font-style: italic;
}

.results-header {
  margin-bottom: var(--spacing-lg);
}

.results-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  letter-spacing: 0.1em;
}
